APP_NAME=NexTrace
APP_ENV=production
APP_KEY= # (pon aquí tu clave)
APP_DEBUG=false
APP_URL=https://tusistema.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nextrace
DB_USERNAME=usuario
DB_PASSWORD=contraseña

SESSION_DRIVER=database
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_LIFETIME=120

CACHE_STORE=file
QUEUE_CONNECTION=database

LOG_CHANNEL=daily
LOG_LEVEL=error

MAIL_MAILER=smtp
MAIL_HOST=mail.tusistema.com
MAIL_PORT=587
MAIL_USERNAME=usuario
MAIL_PASSWORD=contraseña
MAIL_FROM_ADDRESS="soporte@tusistema.com"
MAIL_FROM_NAME="NexTrace"

# Storage, Redis, AWS, etc. según tu infraestructura

VITE_APP_NAME="NexTrace"
